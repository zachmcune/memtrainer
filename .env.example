# ---- Backend runtime ----
# Port the Express server listens on (Railway injects PORT automatically)
PORT=8080

# PostgreSQL connection string (Railway Postgres plugin injects DATABASE_URL)
DATABASE_URL="postgresql://user:password@localhost:5432/mnemonica?schema=public"

# ---- Web Push / VAPID ----
# Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Must be a mailto: address or an https: URL (required by Apple/WebKit)
VAPID_SUBJECT="mailto:you@example.com"

# ---- Frontend build-time ----
# Must equal VAPID_PUBLIC_KEY above; exposed to the browser at build time.
VITE_VAPID_PUBLIC_KEY=""
# Base URL of the API. Leave empty when frontend + backend are the same Railway service.
VITE_API_BASE_URL=""
